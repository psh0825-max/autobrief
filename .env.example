# AutoBrief environment configuration
# --- Local development against Google AI Studio (no gcloud needed) ---
# Either GOOGLE_API_KEY or GEMINI_API_KEY works; config.py maps GEMINI_API_KEY -> GOOGLE_API_KEY.
GOOGLE_API_KEY=your-ai-studio-key
GOOGLE_GENAI_USE_VERTEXAI=0

# --- Production on Vertex AI / Cloud Run (set when deploying) ---
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Real delivery via Google APIs (Gmail draft / Calendar / Drive) ---
# Off by default: delivery tools write to outbox/ stubs so eval/offline demos
# never touch the network. To make delivery REAL:
#   1) Create an OAuth Desktop client in GCP, save JSON as
#      autobrief/mcp_server/.google_client_secret.json
#   2) python -m autobrief.mcp_server.google_auth   (one-time browser consent)
#   3) set both flags below
# AUTOBRIEF_ENABLE_MCP=1
# AUTOBRIEF_ENABLE_GOOGLE=1
# AUTOBRIEF_GOOGLE_TOKEN=autobrief/mcp_server/.google_token.json
# AUTOBRIEF_GOOGLE_CLIENT_SECRET=autobrief/mcp_server/.google_client_secret.json

# --- Optional model tier overrides ---
# AUTOBRIEF_FLASH_MODEL=gemini-2.5-flash
# AUTOBRIEF_FLASH_LITE_MODEL=gemini-2.5-flash-lite
# AUTOBRIEF_PRO_MODEL=gemini-2.5-pro
# Set AUTOBRIEF_PRO_MODEL=gemini-2.5-flash during a live demo if Pro is rate-limited.
